# =============================================================================
# Nexo Vending — Variables de entorno (ejemplo)
# =============================================================================
# Copiá este archivo a `.env.local` para desarrollo local:
#   cp .env.example .env.local
#
# Para producción configurá estas mismas variables en Vercel:
#   Vercel Dashboard → Project → Settings → Environment Variables
#
# IMPORTANTE:
#   - Marcá como "Sensitive" en Vercel todas las variables que NO empiezan con
#     NEXT_PUBLIC_ (las publicas se inyectan al bundle del cliente).
#   - NUNCA commitees .env.local ni .env.production al repo.
#   - Rotá los secretos cada 90 días.
# =============================================================================


# -----------------------------------------------------------------------------
# Site — URL canónica del sitio en producción.
# -----------------------------------------------------------------------------
# Usado por: SEO (canonicals, sitemap, OG), validación de origen en server actions.
NEXT_PUBLIC_SITE_URL=https://www.nexotech.io


# -----------------------------------------------------------------------------
# Cloudflare Turnstile — verificación anti-bot del formulario de contacto.
# -----------------------------------------------------------------------------
# Sin estas variables el form acepta submits sin verificación de bot
# (modo dev / fallback). En producción es FUERTEMENTE recomendado configurarlo.
#
# Cómo obtener las keys:
#   1. https://dash.cloudflare.com → Turnstile → Add Site
#   2. Configurar dominios: nexotech.io, www.nexotech.io, *.vercel.app (para previews)
#   3. Modo: "Invisible" recomendado para no agregar fricción
#   4. Te da SITE_KEY (cliente) y SECRET_KEY (servidor)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=


# -----------------------------------------------------------------------------
# Upstash Redis — rate limiting distribuido para serverless.
# -----------------------------------------------------------------------------
# Sin estas variables, el rate limit usa memoria local (no es confiable en
# Vercel multi-instance). Para producción configurá Upstash:
#
#   1. Crear cuenta gratis en https://console.upstash.com
#   2. Create Database → Region: us-east-1 (cerca de Vercel) → Free tier
#   3. Click en la DB → REST API → copiar URL y TOKEN
#
# Free tier: 10K commands/día, suficiente para una landing B2B mediana.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# -----------------------------------------------------------------------------
# Database — Neon PostgreSQL (serverless).
# -----------------------------------------------------------------------------
# Connection string usado por @neondatabase/serverless en server actions.
# Es OBLIGATORIO en producción: el form de contacto inserta directo a esta DB.
#
# Cómo obtenerla:
#   1. Vercel Dashboard → Project → Storage → Create Database → Neon
#   2. Vercel inyecta automáticamente DATABASE_URL en el proyecto.
#   3. Para local: copialo desde Vercel → Settings → Env Vars → DATABASE_URL.
#
# Aplicar el schema (primera vez):
#   - Neon Console → SQL Editor → pegá migrations/0001_init_leads.sql → Run.
#
# IMPORTANTE: marcar como "Sensitive" en Vercel. Nunca commitear el valor real.
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require


# -----------------------------------------------------------------------------
# Hash de IP — sal para anonimizar IPs en logs (compliance Habeas Data).
# -----------------------------------------------------------------------------
# Generá uno único con: `openssl rand -hex 32`
# Si lo cambiás, los hashes anteriores no van a matchear (esto es a propósito).
IP_HASH_SALT=cambiame-por-un-string-aleatorio-largo


# -----------------------------------------------------------------------------
# Orígenes adicionales permitidos para Server Actions (opcional).
# -----------------------------------------------------------------------------
# Coma-separado. Útil si tenés múltiples dominios o subdominios apuntando
# a la misma deploy. NEXT_PUBLIC_SITE_URL ya se incluye automáticamente.
# Ejemplo: ALLOWED_ORIGINS=https://nexo.com.co,https://nexotech.co
ALLOWED_ORIGINS=


# -----------------------------------------------------------------------------
# Vercel Analytics + Speed Insights — habilita Page Views y Web Vitals reales.
# -----------------------------------------------------------------------------
# Una sola flag controla ambos productos porque comparten los mismos hosts en CSP:
#   - va.vercel-scripts.com   (script-src)
#   - vitals.vercel-insights.com (connect-src)
#
# Los componentes <Analytics /> y <SpeedInsights /> ya están montados en
# src/app/layout.tsx; sin esta flag en true, el CSP bloquea los scripts y
# no se reportan datos al dashboard de Vercel.
NEXT_PUBLIC_VERCEL_ANALYTICS_ENABLED=false
